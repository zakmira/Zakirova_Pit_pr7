<Window x:Class="Hill.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hill"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>

        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" 
                   Text="Шифр Хилла" 
                   FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,15" 
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10">
            <Label Content="Текст для обработки:" FontWeight="Bold"
                   HorizontalAlignment="Center"/>
            <TextBox x:Name="TextInput" 
                     TextChanged="TextInput_TextChanged"
                     Width="180" Height="30" 
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
            <Label Content="Ключевая матрица:"
                   FontWeight="Bold" HorizontalAlignment="Center"/>

            <ComboBox x:Name="MatrixSize" 
                      ToolTip="Размер матрицы"
                      Width="80" 
                      Margin="0,0,0,10"
                      HorizontalAlignment="Center" 
                      SelectionChanged="MatrixSize_SelectionChanged">
                <ComboBoxItem Content="2×2" IsSelected="True"/>
                <ComboBoxItem Content="3×3"/>
            </ComboBox>

            <Grid x:Name="Grid2x2" Margin="0,0,0,10" 
                  HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="M00" Grid.Row="0" 
                         Grid.Column="0" Text="1" 
                         ToolTip="Элемент [0,0]" 
                         TextChanged="Matrix_TextChanged"
                         TextAlignment="Center"/>
                <TextBox x:Name="M01" Grid.Row="0" 
                         Grid.Column="1" Text="2"
                         ToolTip="Элемент [0,1]" 
                         TextChanged="Matrix_TextChanged"
                         TextAlignment="Center"/>
                <TextBox x:Name="M10" Grid.Row="1" 
                         Grid.Column="0" Text="3"
                         ToolTip="Элемент [1,0]" 
                         TextChanged="Matrix_TextChanged"
                         TextAlignment="Center"/>
                <TextBox x:Name="M11" Grid.Row="1" 
                         Grid.Column="1" Text="4"
                         ToolTip="Элемент [1,1]" 
                         TextChanged="Matrix_TextChanged"
                         TextAlignment="Center"/>
            </Grid>

            <Grid x:Name="Grid3x3" Margin="0,0,0,10" 
                  HorizontalAlignment="Center" 
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="M3_00" Grid.Row="0" 
                         Grid.Column="0" Text="1" 
                         ToolTip="[0,0]" TextAlignment="Center"/>
                <TextBox x:Name="M3_01" Grid.Row="0" 
                         Grid.Column="1" Text="1" 
                         ToolTip="[0,1]" TextAlignment="Center"/>
                <TextBox x:Name="M3_02" Grid.Row="0"
                         Grid.Column="2" Text="0" 
                         ToolTip="[0,2]" TextAlignment="Center"/>
                <TextBox x:Name="M3_10" Grid.Row="1" 
                         Grid.Column="0" Text="0" 
                         ToolTip="[1,0]" TextAlignment="Center"/>
                <TextBox x:Name="M3_11" Grid.Row="1" 
                         Grid.Column="1" Text="1" 
                         ToolTip="[1,1]" TextAlignment="Center"/>
                <TextBox x:Name="M3_12" Grid.Row="1" 
                         Grid.Column="2" Text="1" 
                         ToolTip="[1,2]" TextAlignment="Center"/>
                <TextBox x:Name="M3_20" Grid.Row="2" 
                         Grid.Column="0" Text="1" 
                         ToolTip="[2,0]" TextAlignment="Center"/>
                <TextBox x:Name="M3_21" Grid.Row="2" 
                         Grid.Column="1" Text="0" 
                         ToolTip="[2,1]" TextAlignment="Center"/>
                <TextBox x:Name="M3_22" Grid.Row="2" 
                         Grid.Column="2" Text="1" 
                         ToolTip="[2,2]" TextAlignment="Center"/>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20">
            <Button x:Name="Encrypt" 
                    Content="Зашифровать"
                    Width="120" Height="30" Margin="10" 
                    Click="Encrypt_Click" 
                    Background="#4CAF50" 
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button x:Name="Decrypt"
                    Content="Расшифровать" 
                    Width="120" Height="30" Margin="10"
                    Click="Decrypt_Click"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" 
                    Margin="10" HorizontalAlignment="Center">
            <Label Content="Результат:" FontWeight="Bold"
                   HorizontalAlignment="Center"/>
            <TextBox x:Name="Result" 
                     Width="180" Height="60"
                     TextWrapping="Wrap" 
                     IsReadOnly="True" 
                     Background="#F0F0F0"
                     FontSize="14"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>